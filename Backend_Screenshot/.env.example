# ─────────────────────────────────────────────────────────────
# Creative Scanner Pro — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# SQLite (default, local dev only — data lost on Render restart):
DATABASE_URL=sqlite:///./scanner.db

# PostgreSQL (Render / production — persistent):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ──────────────────────────────────────────────────
# Protects all API endpoints. Leave blank to disable (dev only).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── AI Vision (optional) ──────────────────────────────────────
# Claude Vision-powered ad slot detection.
# Leave blank to use DOM scanner only (no API cost).
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────
APP_ENV=development        # development | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# ── Browser engine ────────────────────────────────────────────
HEADLESS=true
ENGINE_CONCURRENCY=5       # Lower for cloud: 3 on free tier, 8 on starter
ENGINE_NAV_TIMEOUT_MS=45000
